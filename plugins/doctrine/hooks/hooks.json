{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "doctrine boot --emit"
          }
        ],
        "matcher": "startup|clear"
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "doctrine worktree create-fork"
          }
        ]
      }
    ]
  }
}
